bindkey -r "^H"  # Unbind Ctrl+h
bindkey -r "^J"  # Unbind Ctrl+j
bindkey -r "^K"  # Unbind Ctrl+k
bindkey -r "^L"  # Unbind Ctrl+l

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="takashiyoshida"

plugins=(
	git
	zsh-autosuggestions
)

source $ZSH/oh-my-zsh.sh

alias vim='nvim'
alias ll='ls -l'
alias ls='colorls'

export PATH="$PATH:$HOME/.local/bin:$HOME/go/bin"

# Add Ruby user gem binaries to PATH (for user-installed gems like colorls)
if command -v ruby &>/dev/null; then
  export PATH="$PATH:$(ruby -e 'print Gem.user_dir')/bin"
fi

set -o vi
bindkey -M viins '^F' autosuggest-accept

# Source machine/OS-specific config if it exists
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
